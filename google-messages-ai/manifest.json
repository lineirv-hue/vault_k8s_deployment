{
  "manifest_version": 3,
  "name": "Google Messages AI Assistant",
  "version": "1.0.0",
  "description": "AI-powered reply assistant for Google Messages using Chrome's built-in Gemini Nano (no remote calls).",
  "permissions": ["storage"],
  "host_permissions": [
    "https://messages.google.com/*",
    "http://localhost:11434/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://messages.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://messages.google.com/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Messages AI Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
