{
  "kubeconfig_path": "~/.kube/config",
  "namespace": "default",
  "vault_image": "hashicorp/vault:1.15.2",
  "node_port": 32000,
  "pv_host_path": "/tmp/vault-data",
  "vault_ui_enabled": true,
  "vault_listener_address": "0.0.0.0",
  "vault_listener_port": 8200,
  "vault_tls_disable": true,
  "vault_storage_path": "/vault/data",
  "vault_disable_mlock": true,
  "vault_log_level": "info",
  "vault_log_dir": "/vault/logs",
  "vault_log_file": "vault.log",
  "vault_rotate_size": "50M",
  "vault_rotate_rotate": 5,
  "vault_rotate_compress": true,
  "vault_rotate_copytruncate": true
}
